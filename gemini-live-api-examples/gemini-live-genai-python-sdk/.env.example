GEMINI_API_KEY=
MODEL=gemini-3.1-flash-live-preview

# ---- Plivo (phone calls) ----
# From your Plivo console. PLIVO_FROM_NUMBER must be a Plivo number you own (E.164).
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
# Public https URL Plivo can reach for the /plivo/answer webhook (e.g. an ngrok tunnel).
PUBLIC_URL=

# ---- Admin dashboard ----
# Key required to open /admin and call /api/admin/* (X-Admin-Key header / ?key=)
ANALYTICS_SECRET=eo2026

# ---- Call log + cost storage ----
# JSON call records are written to DATA_DIR/calls/<id>.json.
DATA_DIR=

# ---- Gemini cost rates (USD per 1,000,000 tokens, paid tier) ----
RATE_GEMINI_TEXT_IN=0.75
RATE_GEMINI_AUDIO_IN=3.00
RATE_GEMINI_IMGVID_IN=1.00
RATE_GEMINI_TEXT_OUT=4.50
RATE_GEMINI_AUDIO_OUT=12.00

# ---- Telephony fallback rate (USD per minute) ----
RATE_TWILIO_PER_MIN=0.014
